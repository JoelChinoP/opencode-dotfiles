# =====================================================================
#  opencode-dotfiles - configuracion central (EDITABLE)
#  Formato KEY=valor. Compatible con `source` de bash y con el parser
#  de los scripts PowerShell. NO pongas espacios alrededor del '='.
#  (Comentarios en ASCII a proposito, para evitar problemas de encoding
#   al cruzar Windows <-> WSL.)
# =====================================================================

# Distribucion WSL a usar. Recomendada y por defecto: Debian.
WSL_DISTRO=Debian

# Carpeta de trabajo del servidor OpenCode. Si es relativa, se resuelve desde
# el HOME del usuario WSL. Ej: .config/opencode => ~/.config/opencode.
OPENCODE_WORKDIR=.config/opencode

# Puerto del servidor API headless (`opencode serve`) al que se conecta la
# web UI, la app de escritorio y el SDK. 4096 es el puerto convencional de
# OpenCode. Con networkingMode=mirrored, Windows llega via localhost:4096.
OPENCODE_SERVE_PORT=4096

# Contrasena del servidor (HTTP Basic Auth). Vacio = sin autenticacion.
# Si la defines, el usuario por defecto es 'opencode'.
# Recomendado ponerla si vas a exponer el puerto fuera de localhost.
OPENCODE_SERVER_PASSWORD=

# --- Skills + configuracion global (paso opcional, ver arch/skills.sh / wsl/skills.sh) ---
# Repo de Anthropic con los skills oficiales. Lo clona skills.sh con sparse-checkout.
SKILLS_REPO=https://github.com/anthropics/skills
# Rama o tag a usar. Por defecto 'main' (rolling, siempre al dia).
# Si quieres reproducibilidad estricta, pinealo a un commit/tag concreto.
SKILLS_REF=main
