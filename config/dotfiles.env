# =====================================================================
#  opencode-dotfiles - configuracion central (EDITABLE)
#  Formato KEY=valor. Compatible con `source` de bash y con el parser
#  de los scripts PowerShell. NO pongas espacios alrededor del '='.
#  (Comentarios en ASCII a proposito, para evitar problemas de encoding
#   al cruzar Windows <-> WSL.)
# =====================================================================

# Distribucion WSL a usar. Recomendada y por defecto: Debian.
WSL_DISTRO=Debian

# Carpeta de trabajo del servidor OpenCode, relativa al HOME del usuario
# de WSL. Vive en el filesystem nativo ext4 (~/code) => maximo rendimiento
# de I/O (sin el puente lento /mnt/ de Windows).
OPENCODE_WORKDIR=code

# Puerto interno (poco usado) donde escucha `opencode web`, SOLO en 127.0.0.1.
# El proxy (nginx/Caddy) es quien expone el dominio publico.
OPENCODE_PORT=47917

# Puerto del servidor API headless (`opencode serve`) al que se conecta la
# APP DE ESCRITORIO y el SDK. 4096 es el puerto convencional de OpenCode.
# Con networkingMode=mirrored, la app en Windows llega via http://localhost:4096.
OPENCODE_SERVE_PORT=4096

# Dominio local para abrir en el navegador.
OPENCODE_DOMAIN=opencode.local

# Contrasena del servidor (HTTP Basic Auth). Vacio = sin autenticacion.
# Si la defines, el usuario por defecto es 'opencode'.
# Recomendado ponerla si vas a exponer el puerto fuera de localhost.
OPENCODE_SERVER_PASSWORD=
